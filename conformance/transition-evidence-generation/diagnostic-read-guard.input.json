{
  "ruleVersion": "lb.http.effective-view.diagnostic-read-guard.v1",
  "guardLifetimeSeconds": 120,
  "request": {
    "targetId": "lb:obj:target-1",
    "generation": "evidence:sha256:guarded-generation",
    "cursorValid": true,
    "targetMatches": true,
    "generationMatches": true,
    "cursorLeaseActive": true,
    "limitValid": true,
    "snapshotRetained": true,
    "deleteClaimCommitted": false
  },
  "guard": {
    "issuedAtEpochSeconds": 1000,
    "expiresAtEpochSeconds": 1120,
    "readCompletedAtEpochSeconds": 1100
  },
  "raceCases": [
    {
      "name": "reader-wins",
      "guardCommitted": true,
      "deleteClaimCommitted": false,
