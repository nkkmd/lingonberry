    },
    {
      "name": "gc-wins",
      "guardCommitted": false,
      "deleteClaimCommitted": true,
      "expected": "generation-unavailable"
    }
  ],
  "expected": {
    "guardAcquired": true,
    "guardActiveAtReadCompletion": true,
    "guardLifetimeSeconds": 120,
    "partialPageAllowed": false,
    "generationSwitchAllowed": false,
    "expiredGuardPinsSnapshot": false,
    "generationUnavailableCode": "LB_DIAGNOSTIC_GENERATION_UNAVAILABLE",
