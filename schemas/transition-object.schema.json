{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lingonberry.cultivationdata.net/schemas/v1/transition-object.schema.json",
  "title": "Lingonberry Transition Object",
  "type": "object",
  "required": ["id", "schemaVersion", "objectType", "transitionType", "targetId", "issuedAt", "provenance", "rawRef"],
  "properties": {
    "id": {"type": "string", "pattern": "^lb:transition:[A-Za-z0-9._~:-]+$"},
    "schemaVersion": {"type": "string", "const": "0.1.0"},
    "objectType": {"type": "string", "const": "transition"},
    "transitionType": {"type": "string", "enum": ["replace", "withdraw"]},
    "targetId": {"type": "string", "pattern": "^lb:obj:[A-Za-z0-9._~:-]+$"},
    "replacementId": {"type": "string", "pattern": "^lb:obj:[A-Za-z0-9._~:-]+$"},
    "supersedesTransitionIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^lb:transition:[A-Za-z0-9._~:-]+$"}
    },
    "issuedAt": {"type": "string", "format": "date-time"},
    "reason": {"type": "string", "minLength": 1},
    "provenance": {"$ref": "knowledge-object.schema.json#/properties/provenance"},
    "rawRef": {"$ref": "knowledge-object.schema.json#/properties/rawRef"},
    "identityClaims": {"type": "array"},
    "meta": {"type": "object", "additionalProperties": true}
  },
  "allOf": [
    {
      "if": {"properties": {"transitionType": {"const": "replace"}}},
      "then": {"required": ["replacementId"]}
    },
    {
      "if": {"properties": {"transitionType": {"const": "withdraw"}}},
      "then": {"not": {"required": ["replacementId"]}}
    }
  ],
  "additionalProperties": false
}
